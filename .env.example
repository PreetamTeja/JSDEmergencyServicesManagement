# Copy to .env.local and fill in. No secrets belong here — the browser
# authenticates with the user's Cognito JWT; API keys are server-side only.

# Deployed backend API base (API Gateway HTTP API)
VITE_API_URL=https://<your-api-id>.execute-api.<region>.amazonaws.com

# Power BI (optional)
VITE_POWERBI_SECURE=
VITE_POWERBI_EMBED_URL=

# Jamshedpur SSO platform (main app) — where to bounce for login
VITE_MAIN_APP_URL=http://localhost:5173

# Shared Cognito user pool
VITE_COGNITO_REGION=<region>
VITE_COGNITO_USER_POOL_ID=<pool-id>
VITE_COGNITO_CLIENT_ID=<client-id>
VITE_COGNITO_DOMAIN=https://<pool>.auth.<region>.amazoncognito.com

# Admin groups (comma-separated). Empty = any group ending in -admin is admin.
VITE_ADMIN_GROUPS=transport-admin

# Voice agent Lambda Function URL
VITE_VOICE_URL=https://<voice-fn>.execute-api.<region>.amazonaws.com
